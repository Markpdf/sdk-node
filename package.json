{
  "name": "@markpdf/sdk",
  "version": "0.1.1",
  "description": "Official Node.js / TypeScript SDK for the markpdf (Flash PDF to Markdown) API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "SECURITY.md", "STORAGE.md", "AGENTS.md", "SKILL.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["pdf", "markdown", "ocr", "document-conversion", "rag"],
  "license": "MIT",
  "homepage": "https://markpdf.tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/markpdf/markpdf-node"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
